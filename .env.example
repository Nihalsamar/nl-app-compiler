# Copy to .env and fill in a key.
# Providers: "nvidia" (NVIDIA NIM), "gemini" (Google), or "mock" (offline).
LLM_PROVIDER=nvidia

# NVIDIA NIM -- get a key at https://build.nvidia.com/
NVIDIA_API_KEY=
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1
NVIDIA_MODEL=meta/llama-3.3-70b-instruct

# Google Gemini -- get a key at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

LLM_TEMPERATURE=0
LLM_MAX_TOKENS=4096
